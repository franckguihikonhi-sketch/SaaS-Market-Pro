NODE_ENV=development
PORT=3001

# Postgres local (docker-compose) pour le développement. En production,
# pointer vers la chaîne de connexion du projet Supabase (Settings > Database,
# utiliser le "Connection pooling" / pgbouncer en production serverless).
DATABASE_URL="postgresql://marketpro:marketpro@localhost:5432/marketpro?schema=public"

# Projet Supabase (Settings > API). service_role ne doit jamais être exposée
# au frontend : elle n'est utilisée que côté API NestJS.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# Origines autorisées pour le CORS (séparées par des virgules).
CORS_ORIGINS="http://localhost:3000"
