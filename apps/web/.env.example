# URL de l'API NestJS (REST + WebSocket).
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# Projet Supabase (Settings > API). L'anon key est publique par design
# (protégée par les policies RLS côté base), contrairement à service_role.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-anon-key"
